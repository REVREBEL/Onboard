{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "app/dist",
  "functions": {
    "api/api/index.js": {
      "includeFiles": "api/survey_modules/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/api/index.js"
    }
  ]
}
